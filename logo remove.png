                      <?php else: ?>
                          <div class="poster-placeholder">POSTER TURNAMEN</div>
                      <?php endif; ?>
                  </div>

                  <div class="slot-info <?= $apakah_penuh ? 'slot-full' : '' ?>">
                      <?= $apakah_penuh ? '🔒 SLOT FULL' : '👥 SLOT TERISI: ' . $terisi . ' / ' . $max_slot ?>
                  </div>
                  
                  <div class="button-group">
                      <?php if ($apakah_penuh): ?>
                          <a href="#" class="btn-action btn-disabled" onclick="alert('Maaf, kuota pendaftaran turnamen ini sudah penuh!'); return false;">PENDAFTARAN TUTUP</a>
                      <?php else: ?>
                          <a href="<?= htmlspecialchars($tur['link_daftar']) ?>?id_tur=<?= $tur['id'] ?>" class="btn-action">DAFTAR SEKARANG</a>
                      <?php endif; ?>
                      
                      <a href="<?= htmlspecialchars($tur['link_braket']) ?>?id_tur=<?= $tur['id'] ?>" class="btn-action btn-secondary">LIHAT BRAKET</a>
                  </div>

              </div>

          <?php endforeach; ?>
      <?php else: ?>
          <p style="text-align: center; color: #9ca3af; font-style: italic;">Saat ini belum ada turnamen yang dibuka.</p>
