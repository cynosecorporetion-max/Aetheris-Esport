<script>
function showRegister(e) {
    if(e) e.preventDefault();
    // Matikan required pada form login agar tidak memblokir browser
    document.getElementsByName('log_username')[0].required = false;
    document.getElementsByName('log_password')[0].required = false;
    
    // Aktifkan required pada form register
    document.getElementsByName('reg_username')[0].required = true;
    document.getElementsByName('reg_password')[0].required = true;

    document.getElementById('form-login-container').style.display = 'none';
    document.getElementById('form-register-container').style.display = 'block';
}

function showLogin(e) {
    if(e) e.preventDefault();
    // Matikan required pada form register
    document.getElementsByName('reg_username')[0].required = false;
    document.getElementsByName('reg_password')[0].required = false;
    
    // Aktifkan required pada form login
    document.getElementsByName('log_username')[0].required = true;
    document.getElementsByName('log_password')[0].required = true;

    document.getElementById('form-register-container').style.display = 'none';
    document.getElementById('form-login-container').style.display = 'block';
}
</script>

