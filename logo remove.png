      <span class="pay-badge">DANA</span>
      <span class="pay-badge">OVO</span>
      <span class="pay-badge">GoPay</span>
      <span class="pay-badge">QRIS</span>
    </div>
  </div>
</footer>

<!-- Floating WA -->
<a href="https://wa.me/628123456789?text=Halo%20MLBoost%2C%20saya%20ingin%20order%20joki%20rank!" target="_blank" class="float-wa" title="Chat WhatsApp">💬</a>

<!-- Order Success Modal -->
<div class="modal-overlay" id="modal">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal()">×</button>
    <div class="modal-icon">🏆</div>
    <h3>ORDER DITERIMA!</h3>
    <p>Terima kasih! Pesananmu sudah kami catat. Tim kami akan segera menghubungimu via WhatsApp dalam waktu kurang dari 30 menit.</p>
    <a href="https://wa.me/628123456789?text=Halo%2C+saya+baru+saja+mengisi+form+order+joki+rank!" target="_blank" class="modal-wa">
      💬 Konfirmasi via WhatsApp
    </a>
  </div>
</div>

<script>
  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => {
          entry.target.classList.add('visible');
        }, 100);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));

  // FAQ
  function toggleFaq(btn) {
    const item = btn.parentElement;
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
    if (!isOpen) item.classList.add('open');
  }

  // Order submit -> kirim ke process_order.php (XAMPP)
  async function submitOrder() {
    const nama = document.getElementById('nama').value.trim();
    const wa = document.getElementById('wa').value.trim();
    const ml_id = document.getElementById('ml_id').value.trim();
    const rank_now = document.getElementById('rank_now').value;
    const rank_target = document.getElementById('rank_target').value;
    const paket = document.getElementById('paket').value;
    const catatan = document.getElementById('catatan').value.trim();

    if (!nama || !wa || !ml_id || !rank_now || !rank_target || !paket) {
      alert('Mohon lengkapi semua field yang wajib diisi!');
      return;
    }

    const fd = new FormData();
    fd.append('nama', nama);
    fd.append('wa', wa);
    fd.append('ml_id', ml_id);
    fd.append('rank_now', rank_now);
    fd.append('rank_target', rank_target);
    fd.append('paket', paket);
    fd.append('catatan', catatan);

    try {
      const res = await fetch('process_order.php', { method: 'POST', body: fd });
      const data = await res.json();
      if (data.ok) {
        document.getElementById('modal').classList.add('active');
        document.querySelectorAll('#nama,#wa,#ml_id,#catatan').forEach(i => i.value = '');
        document.querySelectorAll('#rank_now,#rank_target,#paket').forEach(s => s.selectedIndex = 0);
      } else {
        alert(data.msg || 'Gagal mengirim pesanan');
      }
    } catch (err) {
      alert('Tidak bisa terhubung ke server. Pastikan XAMPP (Apache + MySQL) berjalan.');
    }
  }

  function closeModal() {
    document.getElementById('modal').classList.remove('active');
  }

  document.getElementById('modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

  // Stagger reveal for cards
  document.querySelectorAll('.pricing-grid .price-card, .testi-grid .testi-card, .steps .step').forEach((el, i) => {
    el.style.transitionDelay = (i * 0.1) + 's';
  });
</script>
</body>
</html>
