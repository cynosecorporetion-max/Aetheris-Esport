}

/* 2. Container Card (Diberi jarak bawah yang aman) */
.tournament-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 25px;
  max-width: 1200px;
  
  /* --- PERBAIKAN JARAK BAWAH --- */
