<?php
session_start();
require 'config.php'; 

$error_login = '';
$success_register = '';

// =======================================================
// LOGIKA A: PROSES DAFTAR AKUN BARU (ANTI-BENTROK)
// =======================================================
if (isset($_POST['register_hero'])) {
    $username = mysqli_real_escape_string($conn, trim($_POST['reg_username'] ?? ''));
    $password = $_POST['reg_password'] ?? '';
    
    if (!empty($username) && !empty($password)) {
        // Cek apakah username sudah dipakai orang lain
        $cek_user = $conn->query("SELECT id FROM users WHERE username = '$username'");
        if ($cek_user->num_rows > 0) {
            $error_login = "Username sudah terdaftar! Gunakan nama lain.";
        } else {
            // Enkripsi password
            $password_hashed = password_hash($password, PASSWORD_DEFAULT);
            
            $ins = $conn->prepare("INSERT INTO users (username, password, role) VALUES (?, ?, 'user')");
            $ins->bind_param('ss', $username, $password_hashed);
            if ($ins->execute()) {
                $success_register = "Pendaftaran berhasil! Silakan login.";
            } else {
                $error_login = "Gagal mendaftar: " . $conn->error;
            }
            $ins->close();
        }
    }
}

// =======================================================
// LOGIKA B: PROSES LOGIN (UNTUK SEMUA AKUN)
// =======================================================
if (isset($_POST['login_hero'])) {
    $username = mysqli_real_escape_string($conn, trim($_POST['log_username'] ?? ''));
    $password = $_POST['log_password'] ?? '';

    if (!empty($username) && !empty($password)) {
        $query = "SELECT * FROM users WHERE username = '$username'";
        $result = $conn->query($query);

        if ($result && $result->num_rows > 0) {
            $row = $result->fetch_assoc();
            if (password_verify($password, $row['password'])) {
                $_SESSION['login'] = true;
                $_SESSION['username'] = $row['username'];
                $_SESSION['role'] = $row['role'];
                
                // Paksa refresh halaman menggunakan JavaScript
                echo "<script>window.location.href='index.php';</script>";
                exit;
            } else {
                $error_login = "Password salah!";
            }
        } else {
            $error_login = "Username tidak ditemukan!";
        }
    }
}

// Ambil semua turnamen aktif menggunakan query MySQLi murni tanpa sub-query yang bikin crash
$list_turnamen = [];

// Gunakan try-catch agar jika ada masalah tabel di database, web joki utama TIDAK AKAN ikut rusak/blank
try {
    $query = "SELECT * FROM daftar_turnamen WHERE status_aktif = 'buka' ORDER BY id ASC";
    $result = $conn->query($query);

    if ($result) {
        while ($tur = $result->fetch_assoc()) {
            // Karena kolom pendaftar di database kamu strukturnya berbeda, kita pasang default aman di sini
            $tur['total_pendaftar'] = 0; 
            $list_turnamen[] = $tur;
        }
    }
} catch (Exception $e) {
    // Jika tabel turnamen belum siap/error, halaman web utama tetap akan loading dengan aman
    $list_turnamen = [];
}
?>

