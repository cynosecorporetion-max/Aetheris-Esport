  /* --- ORDER FORM --- */
  .order {
    padding: 6rem 4rem;
    background: var(--dark2);
  }

  .order-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    max-width: 1100px;
    margin: 0 auto;
    align-items: start;
  }

