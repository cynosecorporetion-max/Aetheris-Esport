              $max_slot = !empty($tur['kuota_maksimal']) ? $tur['kuota_maksimal'] : 8;
              $terisi = $tur['total_pendaftar'];
              $apakah_penuh = ($terisi >= $max_slot);
          ?>
              
              <div class="tournament-card reveal">
                  
                  <div class="poster-box">
                      <?php if (file_exists($tur['poster']) && $tur['poster'] != 'default-poster.jpg'): ?>
